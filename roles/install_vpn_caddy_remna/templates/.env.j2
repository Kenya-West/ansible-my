{% set sd = domains_keys.xray_under_dns_balancer | default([]) %}
{% if sd | length > 0 %}
SERVICE_DOMAINS='{{ sd | join(", ") if sd is iterable and sd is not string else sd }}'
LOG_FILE_NAME={{ ansible_hostname }}-remnanode
NODE_PORT={{ remna_node_app_port }}
{% if remna_node_control_port is defined and (remna_node_control_port | default(0)) > 20 %}
EXTERNAL_PORT={{ remna_node_control_port }}
{% endif %}
{% if remna_node_external_ports is defined and (remna_node_external_ports | length) > 0 %}
{% for port in remna_node_external_ports %}
EXTERNAL_{{ loop.index }}_PORT={{ port | string }}
{% endfor %}
{% endif %}
SECRET_KEY='{{ remna_node_ssl_cert_from_panel }}'
{% if remna_node_use_dns01_cloudflare is defined and remna_node_use_dns01_cloudflare == true %}
CLOUDFLARE_API_TOKEN={{ cloudflare_api_token_dns }}
{% endif %}
{% endif %}