{% set domain = domains_keys.remnawave | default(domains_keys.main) %}

REMNAWAVE_PANEL_URL=https://{{ domain }}
EXTERNAL_PORT={{ remna_sub_caddy_external_port | default('') }}
REMNAWAVE_API_TOKEN="{{ vpn_server_remnawave_subscription_api_token }}"
APP_PORT=3010
META_TITLE="{{ vpn_server_remnawave_subscription_meta_title | default('Remnawave Subscription Page') }}"
META_DESCRIPTION="{{ vpn_server_remnawave_subscription_meta_description | default('Remnawave Subscription Page') }}"
SUB_PUBLIC_DOMAIN={{ domains_keys.remnawave_subpage | default(domain) }}/{{ vpn_server_remnawave_subscription_path }}
DOMAIN_FOR_CADDY={{ domains_keys.remnawave_subpage | default(domain) }}
CUSTOM_SUB_PREFIX={{ vpn_server_remnawave_subscription_path | default('sub') }}
CADDY_AUTH_API_TOKEN={{ vpn_server_remnawave_custom_login_route_api_token | default('') }}