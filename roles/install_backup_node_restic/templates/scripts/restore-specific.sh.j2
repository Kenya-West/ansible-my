#! /usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" >/dev/null 2>&1 && pwd)"
. "$SCRIPT_DIR/rclone-pass.sh"

# Default values
TAG="latest"
INCLUDE="*"
CONFIG="{{ dest_project_fullpath }}/config/.autorestic.yaml"
LOCATION="home_user"
TO=~/restored/specific

usage() {
	cat <<EOF
Usage: $(basename "$0") [options]

Options:
	-i, --include PATH    Include path or pattern to restore (required)
	-t, --tag TAG         Restore tag (default: $TAG)
	-c, --config PATH     Path to autorestic config (default: $CONFIG)
	-l, --location NAME   Location name in autorestic (default: $LOCATION)
			--to PATH         Destination directory (default: $TO)
	-h, --help            Show this help
EOF
	exit 1
}

# Parse arguments (supports long options)
while [[ $# -gt 0 ]]; do
	case "$1" in
		-i|--include)
			INCLUDE="$2"; shift 2;;
		-t|--tag)
			TAG="$2"; shift 2;;
		-c|--config)
			CONFIG="$2"; shift 2;;
		-l|--location)
			LOCATION="$2"; shift 2;;
		--to)
			TO="$2"; shift 2;;
		-h|--help)
			usage;;
		--)
			shift; break;;
		*)
			# allow a single positional parameter as include for backward compatibility
			if [[ -z "$INCLUDE" ]]; then
				INCLUDE="$1"; shift
			else
				echo "Unknown argument: $1" >&2
				usage
			fi
			;;
	esac
done

autorestic restore -l "$LOCATION" -c "$CONFIG" "$TAG" --to "$TO" --include "$INCLUDE"