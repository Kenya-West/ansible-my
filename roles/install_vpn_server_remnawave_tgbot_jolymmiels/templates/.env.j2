
{% set bot = vpn_server_remnawave_tgbot_jolymmiels_settings[current_index] %}

DOMAIN_FOR_CADDY={{ domains_keys.remnawave_tgbot_jolymmiels }}
{% if vpn_server_remnawave_tgbot_jolymmiels_external_port is defined %}
EXTERNAL_PORT = {{ vpn_server_remnawave_tgbot_jolymmiels_external_port }}
{% endif %}
SERVICE_NAME = remnawave-telegram-tgbot-jolymmiels-{{ current_index | string }}

HEALTH_CHECK_PORT=3033
REMNAWAVE_HEADERS=X-Api-Key:{{ bot.caddy_with_auth_api_token }}

# Pricing (fiat rub)
PRICE_1={{ bot.pricing.fiat.rub.months_1 | default(100) }}
PRICE_3={{ bot.pricing.fiat.rub.months_3 | default(300) }}
PRICE_6={{ bot.pricing.fiat.rub.months_6 | default(600) }}
PRICE_12={{ bot.pricing.fiat.rub.months_12 | default(1200) }}
# Pricing (tg_stars)
STARS_PRICE_1={{ bot.pricing.tg_stars.months_1 | default(60) }}
STARS_PRICE_3={{ bot.pricing.tg_stars.months_3 | default(120) }}
STARS_PRICE_6={{ bot.pricing.tg_stars.months_6 | default(360) }}
STARS_PRICE_12={{ bot.pricing.tg_stars.months_12 | default(720) }}

TELEGRAM_TOKEN='{{ bot.bot_token }}'

REFERRAL_DAYS={{ bot.referral_days | default(7) }}

MINI_APP_URL={{ bot.miniapp_url }}

DATABASE_URL=postgres://postgres:postgres@db:5432/postgres?sslmode=disable

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres

REMNAWAVE_URL={{ bot.remnawave_url }}
REMNAWAVE_MODE=remote
REMNAWAVE_TOKEN='{{ bot.remnawave_api_token }}'

CRYPTO_PAY_ENABLED={{ (bot.crypto_enabled | default(false)) | string | lower }}
CRYPTO_PAY_TOKEN='{{ bot.crypto_token | default("") }}'
CRYPTO_PAY_URL={{ bot.crypto_pay_url | default('https://pay.crypt.bot') }}

YOOKASA_ENABLED={{ (bot.yookassa_enabled | default(false)) | string | lower }}
YOOKASA_SECRET_KEY='{{ bot.yookassa_token | default("") }}'
YOOKASA_SHOP_ID={{ bot.yookassa_shop_id | default('') }}
YOOKASA_URL={{ bot.yookassa_pay_url | default('https://api.yookassa.ru/v3') }}
YOOKASA_EMAIL={{ bot.yookassa_email | default('') }}

TRIBUTE_ENABLED={{ (bot.tribute_enabled | default(false)) | string | lower }}
TRIBUTE_WEBHOOK_URL={{ bot.tribute_webhook | default('/api/webhook/tribute') }}
TRIBUTE_API_KEY={{ bot.tribute_api_key | default('') }}
TRIBUTE_PAYMENT_URL={{ bot.tribute_payment_url | default('https://t.me/tribute/app?startapp=id') }}

TRAFFIC_LIMIT={{ bot.paid_traffic_limit | default(100) }}

TELEGRAM_STARS_ENABLED={{ (bot.tg_stars_enabled | default(false)) | string | lower }}

TRIAL_TRAFFIC_LIMIT={{ bot.trial_traffic_limit | default(10) }}
TRIAL_DAYS={{ bot.trial_days | default(2) }}

ADMIN_TELEGRAM_ID={{ bot.admin_telegram_id }}

SERVER_STATUS_URL={{ bot.status_url }}
SUPPORT_URL={{ bot.support_url }}
FEEDBACK_URL={{ bot.feedback_url }}
CHANNEL_URL={{ bot.channel_url }}
{% if bot.tos_url is defined %}
TOS_URL={{ bot.tos_url }}
{% endif %}

{% if bot.inbound_uuids is defined and bot.inbound_uuids | length > 0 %}
INBOUND_UUIDS={{ bot.inbound_uuids | join(',') }}
{% endif %}

{% if bot.user_tag is defined and bot.user_tag | length > 0 %}
SQUAD_UUIDS={{ bot.squad_uuids | join(',') }}
{% endif %}

{% if bot.user_tag is defined and bot.user_tag | length > 0 %}
REMNAWAVE_TAG={{ bot.user_tag }}
{% endif %}