SERVICE_DOMAIN={{ domains_keys.matrix_server }}
SERVICE_PORT_INTERNAL=8008
{% if matrix_server_root_domain %}
SERVICE_DOMAIN_ROOT={{ matrix_server_root_domain }}
{% endif %}

SYNAPSE_CONFIG_PATH=/data/homeserver.yaml
POSTGRES_USER=synapse
POSTGRES_PASSWORD={{ matrix_server_postgres_password }}
POSTGRES_INITDB_ARGS=--encoding=UTF-8 --lc-collate=C --lc-ctype=C